# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.md text
*.py text
*.sh text
*.ps1 text
*.toml text
*.json text
*.txt text
*.csv text
*.yaml text
*.yml text

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.mp4 binary
*.mov binary
*.pyc binary
*.pyd binary
*.pyo binary
*.so binary
*.dll binary
*.dylib binary
*.exe binary
